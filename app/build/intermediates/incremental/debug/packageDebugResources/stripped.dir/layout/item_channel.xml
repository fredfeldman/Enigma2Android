<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/channel_item_height"
    android:orientation="horizontal"
    android:background="@drawable/selector_channel_item"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <TextView
        android:id="@+id/tv_channel_number"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:singleLine="true" />

    <ImageView
        android:id="@+id/iv_picon"
        android:layout_width="56dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_now_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <ProgressBar
            android:id="@+id/progress_now"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="3dp"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/surface_elevated" />

        <TextView
            android:id="@+id/tv_next_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:alpha="0.7"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_rec_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REC"
        android:textColor="@color/error"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginEnd="6dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/btn_favorite"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="★"
        android:textSize="20sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="false" />
</LinearLayout>
